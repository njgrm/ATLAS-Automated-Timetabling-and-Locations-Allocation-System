{
  "name": "atlas",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm --prefix atlas-server run dev\" \"npm --prefix atlas-client run dev\"",
    "dev:server": "npm --prefix atlas-server run dev",
    "dev:client": "npm --prefix atlas-client run dev",
    "seed:enrollpro-authoritative": "npm --prefix EnrollPro/server run db:seed-atlas-source",
    "seed:atlas-enrollpro-source": "npm --prefix atlas-server run seed:enrollpro-source --",
    "verify:enrollpro-source": "npm --prefix atlas-server run verify:enrollpro-source --",
    "verify:cross-repo-source-gate": "npm --prefix atlas-server run verify:cross-repo-source-gate --",
    "test:phase4-review": "npm --prefix atlas-server run test:phase4-review",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:bootstrap": "npm run db:generate ; npm run db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "konva": "^10.2.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "vite": "^6.4.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
