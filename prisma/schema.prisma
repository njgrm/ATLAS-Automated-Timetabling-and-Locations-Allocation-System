// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../atlas-server/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id             Int              @id @default(autoincrement())
  name           String
  shortName      String
  campusImageUrl String?          @map("campus_image_url")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subjects       Subject[]
  buildings      Building[]
  facultyMirrors FacultyMirror[]

  @@map("schools")
}

model Building {
  id                 Int      @id @default(autoincrement())
  schoolId           Int      @map("school_id")
  name               String
  shortCode          String?  @map("short_code")
  x                  Float    @default(0)
  y                  Float    @default(0)
  width              Float    @default(200)
  height             Float    @default(120)
  rotation           Float    @default(0)
  color              String   @default("#2563eb")
  floorCount         Int      @default(1) @map("floor_count")
  isTeachingBuilding Boolean  @default(true) @map("is_teaching_building")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms              Room[]

  @@map("buildings")
}

enum RoomType {
  CLASSROOM
  LABORATORY
  COMPUTER_LAB
  TLE_WORKSHOP
  LIBRARY
  GYMNASIUM
  FACULTY_ROOM
  OFFICE
  OTHER

  @@map("room_type")
}

model Room {
  id              Int      @id @default(autoincrement())
  buildingId      Int      @map("building_id")
  name            String
  floor           Int      @default(1)
  type            RoomType @default(CLASSROOM)
  capacity        Int?
  isTeachingSpace Boolean  @default(true) @map("is_teaching_space")
  floorPosition   Int      @default(0) @map("floor_position")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  building        Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  requestedRoomPreferences FacultyRoomPreference[] @relation("RequestedRoomPreferences")

  @@map("rooms")
}

enum SessionPattern {
  MWF
  TTH
  ANY

  @@map("session_pattern")
}

model Subject {
  id                      Int              @id @default(autoincrement())
  schoolId                Int              @map("school_id")
  code                    String
  name                    String
  minMinutesPerWeek       Int              @map("min_minutes_per_week")
  preferredRoomType       RoomType         @default(CLASSROOM) @map("preferred_room_type")
  sessionPattern          SessionPattern   @default(ANY) @map("session_pattern")
  gradeLevels             Int[]            @map("grade_levels")
  isActive                Boolean          @default(true) @map("is_active")
  isSeedable              Boolean          @default(false) @map("is_seedable")
  interSectionEnabled     Boolean          @default(false) @map("inter_section_enabled")
  interSectionGradeLevels Int[]            @default([]) @map("inter_section_grade_levels")
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  school                  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facultySubjects         FacultySubject[]

  @@unique([schoolId, code], map: "uq_subjects_school_code")
  @@index([schoolId])
  @@map("subjects")
}

model FacultyMirror {
  id                        Int               @id @default(autoincrement())
  externalId                Int               @map("external_id")
  schoolId                  Int               @map("school_id")
  firstName                 String            @map("first_name")
  lastName                  String            @map("last_name")
  department                String?
  employmentStatus          String            @default("PERMANENT") @map("employment_status")
  contactInfo               String?           @map("contact_info")
  avatarUrl                 String?           @map("avatar_url")
  localNotes                String?           @map("local_notes")
  isActiveForScheduling     Boolean           @default(true) @map("is_active_for_scheduling")
  isClassAdviser            Boolean           @default(false) @map("is_class_adviser")
  advisoryEquivalentHours   Int               @default(0) @map("advisory_equivalent_hours")
  canTeachOutsideDepartment Boolean           @default(false) @map("can_teach_outside_department")
  maxHoursPerWeek           Int               @default(30) @map("max_hours_per_week")
  lastSyncedAt              DateTime          @default(now()) @map("last_synced_at")
  // Stale tracking (Wave 3.5)
  isStale                   Boolean           @default(false) @map("is_stale")
  staleReason               String?           @map("stale_reason")
  staleAt                   DateTime?         @map("stale_at")
  // Adviser mapping (Wave 3.5)
  advisedSectionId          Int?              @map("advised_section_id")
  advisedSectionName        String?           @map("advised_section_name")
  version                   Int               @default(1)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  school                    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facultySubjects           FacultySubject[]
  preferences               FacultyPreference[]
  roomPreferences           FacultyRoomPreference[]
  roomRequestAppeals        RoomRequestAppeal[]

  @@unique([schoolId, externalId], map: "uq_faculty_school_external")
  @@index([schoolId])
  @@index([schoolId, isStale])
  @@map("faculty_mirrors")
}

model FacultySubject {
  id          Int           @id @default(autoincrement())
  facultyId   Int           @map("faculty_id")
  subjectId   Int           @map("subject_id")
  schoolId    Int           @map("school_id")
  gradeLevels Int[]         @map("grade_levels")
  sectionIds  Int[]         @default([]) @map("section_ids")
  assignedBy  Int           @map("assigned_by")
  assignedAt  DateTime      @default(now()) @map("assigned_at")
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  faculty     FacultyMirror @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectId], map: "uq_faculty_subject")
  @@index([schoolId])
  @@index([facultyId])
  @@index([subjectId])
  @@map("faculty_subjects")
}

// ─── Phase 2: Faculty Preferences ───

enum PreferenceStatus {
  DRAFT
  SUBMITTED

  @@map("preference_status")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY

  @@map("day_of_week")
}

enum TimeSlotPreference {
  PREFERRED
  AVAILABLE
  UNAVAILABLE

  @@map("time_slot_preference")
}

model FacultyPreference {
  id           Int              @id @default(autoincrement())
  schoolId     Int              @map("school_id")
  schoolYearId Int              @map("school_year_id")
  facultyId    Int              @map("faculty_id")
  status       PreferenceStatus @default(DRAFT)
  notes        String?
  submittedAt  DateTime?        @map("submitted_at")
  version      Int              @default(1)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  faculty      FacultyMirror    @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  timeSlots    PreferenceTimeSlot[]
  review       PreferenceReview?

  @@unique([schoolId, schoolYearId, facultyId], map: "uq_preference_school_year_faculty")
  @@index([schoolId, schoolYearId])
  @@index([facultyId])
  @@map("faculty_preferences")
}

model PreferenceTimeSlot {
  id           Int                @id @default(autoincrement())
  preferenceId Int                @map("preference_id")
  day          DayOfWeek
  startTime    String             @map("start_time")
  endTime      String             @map("end_time")
  preference   TimeSlotPreference @default(AVAILABLE)
  createdAt    DateTime           @default(now())

  facultyPreference FacultyPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@index([preferenceId])
  @@map("preference_time_slots")
}

// ─── Phase 2: Officer Review Metadata ───

enum ReviewStatus {
  PENDING
  REVIEWED
  NEEDS_FOLLOW_UP

  @@map("review_status")
}

model PreferenceReview {
  id             Int              @id @default(autoincrement())
  preferenceId   Int              @map("preference_id")
  reviewerId     Int              @map("reviewer_id")
  reviewStatus   ReviewStatus     @default(PENDING) @map("review_status")
  reviewerNotes  String?          @map("reviewer_notes")
  reviewedAt     DateTime?        @map("reviewed_at")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  preference     FacultyPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@unique([preferenceId], map: "uq_preference_review")
  @@index([reviewerId])
  @@index([reviewStatus])
  @@map("preference_reviews")
}

enum RoomPreferenceStatus {
  DRAFT
  SUBMITTED

  @@map("room_preference_status")
}

enum RoomPreferenceDecisionStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("room_preference_decision_status")
}

model FacultyRoomPreference {
  id             Int                          @id @default(autoincrement())
  schoolId       Int                          @map("school_id")
  schoolYearId   Int                          @map("school_year_id")
  runId          Int                          @map("run_id")
  entryId        String                       @map("entry_id")
  facultyId      Int                          @map("faculty_id")
  subjectId      Int                          @map("subject_id")
  sectionId      Int                          @map("section_id")
  currentRoomId  Int                          @map("current_room_id")
  requestedRoomId Int                         @map("requested_room_id")
  day            DayOfWeek
  startTime      String                       @map("start_time")
  endTime        String                       @map("end_time")
  rationale      String?
  status         RoomPreferenceStatus         @default(DRAFT)
  submittedAt    DateTime?                    @map("submitted_at")
  version        Int                          @default(1)
  reviewerId     Int?                         @map("reviewer_id")
  decisionStatus RoomPreferenceDecisionStatus @default(PENDING) @map("decision_status")
  reviewerNotes  String?                      @map("reviewer_notes")
  reviewedAt     DateTime?                    @map("reviewed_at")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  faculty        FacultyMirror                @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  requestedRoom  Room                         @relation("RequestedRoomPreferences", fields: [requestedRoomId], references: [id], onDelete: Cascade)
  run            GenerationRun                @relation(fields: [runId], references: [id], onDelete: Cascade)
  appeals        RoomRequestAppeal[]

  @@unique([runId, entryId], map: "uq_room_preference_run_entry")
  @@index([schoolId, schoolYearId, status])
  @@index([schoolId, schoolYearId, decisionStatus])
  @@index([runId, facultyId])
  @@index([requestedRoomId, day, startTime])
  @@map("faculty_room_preferences")
}

enum RoomRequestAppealStatus {
  OPEN
  UNDER_REVIEW
  UPHELD
  DENIED

  @@map("room_request_appeal_status")
}

enum RoomRequestAppealHistoryAction {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  DECISION_RECORDED

  @@map("room_request_appeal_history_action")
}

model RoomRequestAppeal {
  id              Int                            @id @default(autoincrement())
  schoolId        Int                            @map("school_id")
  schoolYearId    Int                            @map("school_year_id")
  runId           Int                            @map("run_id")
  requestId       Int                            @map("request_id")
  requesterId     Int                            @map("requester_id")
  reason          String
  status          RoomRequestAppealStatus        @default(OPEN)
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")

  request         FacultyRoomPreference          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requester       FacultyMirror                  @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  history         RoomRequestAppealHistory[]

  @@index([schoolId, schoolYearId, runId])
  @@index([requestId])
  @@index([requesterId])
  @@map("room_request_appeals")
}

model RoomRequestAppealHistory {
  id              Int                            @id @default(autoincrement())
  appealId        Int                            @map("appeal_id")
  actorId         Int                            @map("actor_id")
  action          RoomRequestAppealHistoryAction
  fromStatus      RoomRequestAppealStatus?       @map("from_status")
  toStatus        RoomRequestAppealStatus?       @map("to_status")
  note            String?
  createdAt       DateTime                       @default(now()) @map("created_at")

  appeal          RoomRequestAppeal              @relation(fields: [appealId], references: [id], onDelete: Cascade)

  @@index([appealId, createdAt])
  @@map("room_request_appeal_history")
}

// ─── Phase 3: Timetable Generation ───

// ─── Scheduling Policy ───

model SchedulingPolicy {
  id                                       Int      @id @default(autoincrement())
  schoolId                                 Int      @map("school_id")
  schoolYearId                             Int      @map("school_year_id")
  maxConsecutiveTeachingMinutesBeforeBreak  Int      @default(120) @map("max_consecutive_teaching_minutes_before_break")
  minBreakMinutesAfterConsecutiveBlock      Int      @default(15) @map("min_break_minutes_after_consecutive_block")
  maxTeachingMinutesPerDay                  Int      @default(400) @map("max_teaching_minutes_per_day")
  earliestStartTime                        String   @default("07:00") @map("earliest_start_time")
  latestEndTime                            String   @default("17:00") @map("latest_end_time")
  enforceConsecutiveBreakAsHard            Boolean  @default(false) @map("enforce_consecutive_break_as_hard")
  enableTravelWellbeingChecks              Boolean  @default(true)  @map("enable_travel_wellbeing_checks")
  maxWalkingDistanceMetersPerTransition    Int      @default(120)   @map("max_walking_distance_meters_per_transition")
  maxBuildingTransitionsPerDay             Int      @default(4)     @map("max_building_transitions_per_day")
  maxBackToBackTransitionsWithoutBuffer    Int      @default(2)     @map("max_back_to_back_transitions_without_buffer")
  maxIdleGapMinutesPerDay                  Int      @default(60)    @map("max_idle_gap_minutes_per_day")
  avoidEarlyFirstPeriod                    Boolean  @default(false) @map("avoid_early_first_period")
  avoidLateLastPeriod                      Boolean  @default(false) @map("avoid_late_last_period")
  enableVacantAwareConstraints             Boolean  @default(false) @map("enable_vacant_aware_constraints")
  targetFacultyDailyVacantMinutes          Int      @default(60)    @map("target_faculty_daily_vacant_minutes")
  targetSectionDailyVacantPeriods          Int      @default(1)     @map("target_section_daily_vacant_periods")
  maxCompressedTeachingMinutesPerDay       Int      @default(300)   @map("max_compressed_teaching_minutes_per_day")
  lunchStartTime                           String   @default("11:55") @map("lunch_start_time")
  lunchEndTime                             String   @default("12:55") @map("lunch_end_time")
  enforceLunchWindow                       Boolean  @default(true)    @map("enforce_lunch_window")
  enableTleTwoPassPriority                 Boolean  @default(true)    @map("enable_tle_two_pass_priority")
  allowFlexibleSubjectAssignment           Boolean  @default(false)   @map("allow_flexible_subject_assignment")
  allowConsecutiveLabSessions              Boolean  @default(false)   @map("allow_consecutive_lab_sessions")
  constraintConfig                         Json?    @map("constraint_config")
  createdAt                                DateTime @default(now())
  updatedAt                                DateTime @updatedAt

  @@unique([schoolId, schoolYearId])
  @@map("scheduling_policies")
}

// ─── Generation Run ───

enum GenerationRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED

  @@map("generation_run_status")
}

model GenerationRun {
  id              Int                  @id @default(autoincrement())
  schoolId        Int                  @map("school_id")
  schoolYearId    Int                  @map("school_year_id")
  status          GenerationRunStatus  @default(QUEUED)
  runType         String               @default("FULL") @map("run_type")
  triggeredBy     Int                  @map("triggered_by")
  startedAt       DateTime?            @map("started_at")
  finishedAt      DateTime?            @map("finished_at")
  durationMs      Int?                 @map("duration_ms")
  summary         Json?
  violations      Json?
  draftEntries    Json?                @map("draft_entries")
  unassignedItems Json?                @map("unassigned_items")
  error           String?
  version         Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  manualEdits     ManualScheduleEdit[]
  roomPreferences FacultyRoomPreference[]

  @@index([schoolId, schoolYearId, createdAt])
  @@index([status])
  @@map("generation_runs")
}

// ─── Manual Schedule Edit ───

enum ManualEditType {
  PLACE_UNASSIGNED
  MOVE_ENTRY
  CHANGE_ROOM
  CHANGE_FACULTY
  CHANGE_TIMESLOT
  REVERT

  @@map("manual_edit_type")
}

model ManualScheduleEdit {
  id              Int            @id @default(autoincrement())
  runId           Int            @map("run_id")
  schoolId        Int            @map("school_id")
  schoolYearId    Int            @map("school_year_id")
  actorId         Int            @map("actor_id")
  editType        ManualEditType @map("edit_type")
  beforePayload   Json           @map("before_payload")
  afterPayload    Json           @map("after_payload")
  validationSummary Json?        @map("validation_summary")
  createdAt       DateTime       @default(now())

  run             GenerationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([schoolId, schoolYearId])
  @@map("manual_schedule_edits")
}

// ─── Audit Log ───

model AuditLog {
  id           Int      @id @default(autoincrement())
  schoolId     Int      @map("school_id")
  schoolYearId Int?     @map("school_year_id")
  action       String
  actorId      Int      @map("actor_id")
  targetIds    Int[]    @map("target_ids")
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([schoolId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Follow-Up Flag ───

model FollowUpFlag {
  id        Int      @id @default(autoincrement())
  runId     Int      @map("run_id")
  entryId   String   @map("entry_id")
  note      String?
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now())

  @@unique([runId, entryId])
  @@index([runId])
  @@map("follow_up_flags")
}

// ─── Pre-Generation Locked Sessions ───

enum PreGenerationDraftStatus {
  DRAFT
  LOCKED_FOR_RUN
  ARCHIVED

  @@map("pre_generation_draft_status")
}

enum PreGenerationDraftEntryKind {
  SECTION
  COHORT

  @@map("pre_generation_draft_entry_kind")
}

model LockedSession {
  id           Int      @id @default(autoincrement())
  schoolId     Int      @map("school_id")
  schoolYearId Int      @map("school_year_id")
  entryKind    PreGenerationDraftEntryKind @default(SECTION) @map("entry_kind")
  sectionId    Int      @map("section_id")
  subjectId    Int      @map("subject_id")
  facultyId    Int?     @map("faculty_id")
  roomId       Int?     @map("room_id")
  cohortCode   String?  @map("cohort_code")
  status       PreGenerationDraftStatus @default(DRAFT)
  lockedRunId  Int?     @map("locked_run_id")
  notes        String?
  version      Int      @default(1)
  day          DayOfWeek
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  createdBy    Int      @map("created_by")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  actions      LockedSessionAction[]

  @@unique([schoolId, schoolYearId, entryKind, sectionId, subjectId, cohortCode, day, startTime], map: "uq_locked_session")
  @@index([schoolId, schoolYearId])
  @@index([schoolId, schoolYearId, status])
  @@index([lockedRunId])
  @@map("locked_sessions")
}

model LockedSessionAction {
  id            Int      @id @default(autoincrement())
  lockId         Int?     @map("lock_id")
  schoolId       Int      @map("school_id")
  schoolYearId   Int      @map("school_year_id")
  actorId        Int      @map("actor_id")
  actionType     String   @map("action_type")
  beforePayload  Json?    @map("before_payload")
  afterPayload   Json?    @map("after_payload")
  createdAt      DateTime @default(now())

  lock          LockedSession? @relation(fields: [lockId], references: [id], onDelete: SetNull)

  @@index([lockId, createdAt])
  @@index([schoolId, schoolYearId, createdAt])
  @@map("locked_session_actions")
}

// ─── Grade Shift Windows ───

model GradeShiftWindow {
  id           Int      @id @default(autoincrement())
  schoolId     Int      @map("school_id")
  schoolYearId Int      @map("school_year_id")
  gradeLevel   Int      @map("grade_level")
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, schoolYearId, gradeLevel], map: "uq_grade_shift_window")
  @@index([schoolId, schoolYearId])
  @@map("grade_shift_windows")
}

// ─── Wave 3.5: Durable Cache (Source-of-Truth Hardening) ───

model FacultySnapshot {
  id           Int      @id @default(autoincrement())
  schoolId     Int      @map("school_id")
  schoolYearId Int      @map("school_year_id")
  fetchedAt    DateTime @default(now()) @map("fetched_at")
  source       String   @default("enrollpro")
  checksum     String?
  schemaVersion Int     @default(1) @map("schema_version")
  payload      Json
  createdAt    DateTime @default(now())

  @@unique([schoolId, schoolYearId], map: "uq_faculty_snapshot_school_year")
  @@index([schoolId, fetchedAt])
  @@map("faculty_snapshots")
}

model SectionSnapshot {
  id           Int      @id @default(autoincrement())
  schoolId     Int      @map("school_id")
  schoolYearId Int      @map("school_year_id")
  fetchedAt    DateTime @default(now()) @map("fetched_at")
  source       String   @default("enrollpro")
  checksum     String?
  schemaVersion Int     @default(1) @map("schema_version")
  payload      Json
  createdAt    DateTime @default(now())

  @@unique([schoolId, schoolYearId], map: "uq_section_snapshot_school_year")
  @@index([schoolId, fetchedAt])
  @@map("section_snapshots")
}

// ─── Wave 3.5: Special Program Types ───

enum ProgramType {
  REGULAR
  STE
  SPS
  SPA
  OTHER

  @@map("program_type")
}

// ─── Wave 3.5: TLE Inter-section Cohorts ───

model InstructionalCohort {
  id                  Int       @id @default(autoincrement())
  schoolId            Int       @map("school_id")
  schoolYearId        Int       @map("school_year_id")
  cohortCode          String    @map("cohort_code")
  specializationCode  String    @map("specialization_code")
  specializationName  String    @map("specialization_name")
  gradeLevel          Int       @map("grade_level")
  memberSectionIds    Int[]     @map("member_section_ids")
  expectedEnrollment  Int       @default(0) @map("expected_enrollment")
  preferredRoomType   RoomType? @map("preferred_room_type")
  isActive            Boolean   @default(true) @map("is_active")
  sourceRef           String?   @map("source_ref")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([schoolId, schoolYearId, cohortCode], map: "uq_cohort_code")
  @@index([schoolId, schoolYearId, gradeLevel])
  @@map("instructional_cohorts")
}
