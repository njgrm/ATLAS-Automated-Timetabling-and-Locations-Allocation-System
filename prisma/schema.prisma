// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../atlas-server/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id             Int              @id @default(autoincrement())
  name           String
  shortName      String
  campusImageUrl String?          @map("campus_image_url")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subjects       Subject[]
  buildings      Building[]
  facultyMirrors FacultyMirror[]

  @@map("schools")
}

model Building {
  id        Int      @id @default(autoincrement())
  schoolId  Int      @map("school_id")
  name      String
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(200)
  height    Float    @default(120)
  color     String   @default("#2563eb")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms     Room[]

  @@map("buildings")
}

enum RoomType {
  CLASSROOM
  LABORATORY
  COMPUTER_LAB
  TLE_WORKSHOP
  LIBRARY
  GYMNASIUM
  FACULTY_ROOM
  OFFICE
  OTHER

  @@map("room_type")
}

model Room {
  id         Int      @id @default(autoincrement())
  buildingId Int      @map("building_id")
  name       String
  floor      Int      @default(1)
  type       RoomType @default(CLASSROOM)
  capacity   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("rooms")
}

model Subject {
  id                Int              @id @default(autoincrement())
  schoolId          Int              @map("school_id")
  code              String
  name              String
  minMinutesPerWeek Int              @map("min_minutes_per_week")
  preferredRoomType RoomType         @default(CLASSROOM) @map("preferred_room_type")
  gradeLevels       Int[]            @map("grade_levels")
  isActive          Boolean          @default(true) @map("is_active")
  isSeedable        Boolean          @default(false) @map("is_seedable")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facultySubjects   FacultySubject[]

  @@unique([schoolId, code], map: "uq_subjects_school_code")
  @@index([schoolId])
  @@map("subjects")
}

model FacultyMirror {
  id                    Int              @id @default(autoincrement())
  externalId            Int              @map("external_id")
  schoolId              Int              @map("school_id")
  firstName             String           @map("first_name")
  lastName              String           @map("last_name")
  department            String?
  contactInfo           String?          @map("contact_info")
  localNotes            String?          @map("local_notes")
  isActiveForScheduling Boolean          @default(true) @map("is_active_for_scheduling")
  maxHoursPerWeek       Int              @default(30) @map("max_hours_per_week")
  lastSyncedAt          DateTime         @default(now()) @map("last_synced_at")
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  school                School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facultySubjects       FacultySubject[]

  @@unique([schoolId, externalId], map: "uq_faculty_school_external")
  @@index([schoolId])
  @@map("faculty_mirrors")
}

model FacultySubject {
  id          Int           @id @default(autoincrement())
  facultyId   Int           @map("faculty_id")
  subjectId   Int           @map("subject_id")
  schoolId    Int           @map("school_id")
  gradeLevels Int[]         @map("grade_levels")
  assignedBy  Int           @map("assigned_by")
  assignedAt  DateTime      @default(now()) @map("assigned_at")
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  faculty     FacultyMirror @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectId], map: "uq_faculty_subject")
  @@index([schoolId])
  @@index([facultyId])
  @@index([subjectId])
  @@map("faculty_subjects")
}
