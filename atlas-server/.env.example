# Atlas Server
DATABASE_URL=postgresql://atlas_user:incorrect404@localhost:5432/atlas_db?schema=public
JWT_SECRET="change-this-to-a-random-32-char-minimum-secret-key"
PORT=5001
ENROLLPRO_API=http://localhost:5000/api
CLIENT_URL=http://localhost:5174

# Faculty adapter: "stub" (default) or "enrollpro"
FACULTY_ADAPTER=stub
# Required when FACULTY_ADAPTER=enrollpro — a valid EnrollPro JWT with SYSTEM_ADMIN role
ENROLLPRO_SERVICE_TOKEN=

# Section source mode: enrollpro | stub | auto
#   enrollpro — always fetch live sections from EnrollPro (recommended for integration testing)
#   stub      — always use deterministic test sections (10 sections, 334 enrolled)
#   auto      — try EnrollPro first, fallback to stub with warning
# WARNING: stub mode produces fewer sections than real EnrollPro and counts will not match.
# Recommended for local dev with EnrollPro running: enrollpro
SECTION_SOURCE_MODE=enrollpro

# When true and SECTION_SOURCE_MODE=auto, fail fast instead of silently falling back to stub.
# SECTION_STRICT_UPSTREAM=false
