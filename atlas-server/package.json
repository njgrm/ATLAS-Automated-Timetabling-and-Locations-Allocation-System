{
  "name": "atlas-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed:enrollpro-source": "tsx src/scripts/seed-realistic.ts",
    "seed:atlas-fixture": "tsx src/scripts/seed-realistic.ts --mode=atlas-fixture --confirmFixtureBypass=true",
    "seed:qa-room-requests": "tsx src/scripts/seed-qa-room-requests.ts",
    "verify:enrollpro-source": "tsx src/scripts/verify-enrollpro-source.ts",
    "verify:cross-repo-source-gate": "tsx src/scripts/verify-cross-repo-source-gate.ts",
    "test:phase4-review": "tsx src/__tests__/phase4-cohort-review.test.ts",
    "test:wave4.3": "tsx src/__tests__/wave4-pre-generation-draft.test.ts",
    "test:wave4-precision": "tsx ../qa-artifacts/wave4-teaching-load-precision.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
