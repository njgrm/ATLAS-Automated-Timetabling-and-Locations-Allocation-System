# ATLAS client environment variables
# Copy to .env and adjust for your environment

# URL of the EnrollPro frontend (used for "Back to EnrollPro" link)
VITE_ENROLLPRO_URL=http://localhost:5173

# Base URL of EnrollPro API backend (used by Vite proxy /enrollpro-api)
VITE_ENROLLPRO_API_BASE=http://localhost:5000

# Base URL of ATLAS API backend (used by Vite proxy /api)
# Leave unset to use the default localhost:5001
# VITE_ATLAS_API=http://localhost:5001

# --- Tailscale / LAN example (uncomment and adjust) ---
# VITE_ENROLLPRO_URL=http://100.88.55.125:5173
# VITE_ENROLLPRO_API_BASE=http://100.88.55.125:5000
# VITE_ATLAS_API=http://100.88.55.125:5001
